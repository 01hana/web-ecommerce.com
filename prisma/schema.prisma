generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email     String   @unique
  hash      String
  name      String
  mobile    String
  address   String

  @@map("customers")
}

model products {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  name        String
  price       Float
  image       String
  category    String
  status      Boolean  @default(true)
  description String?
  stock       Int      @default(0)
}

model users {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime

  email     String   @unique
  hash      String
  name      String
  groups    String[]
  status    Boolean  @default(true)
  account   String   @unique
}
